# VELOX Server settings. Copy to .env and adjust. Never commit .env.

# Bearer token required on API routes. Empty/unset disables auth
# (local development only - set a token before exposing the server).
VELOX_API_TOKEN=

# Root logging level: DEBUG, INFO, WARNING, ERROR, CRITICAL.
VELOX_LOG_LEVEL=INFO

# How many times a transiently failed action is re-queued.
VELOX_MAX_TRANSIENT_RETRIES=3
